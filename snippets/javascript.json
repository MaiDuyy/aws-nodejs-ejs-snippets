{
  "Express App Boilerplate": {
    "prefix": "ex-app",
    "body": [
      "import express from \"express\";",
      "import dotenv from \"dotenv\";",
      "import router from \"./routes/${1:soft}.route.js\";",
      "",
      "const app = express(); ",
      "dotenv.config(); ",
      "app.set(\"view engine\", \"ejs\"); ",
      "app.use(express.urlencoded({ extended: true })); ",
      "app.use(\"/\", router);",
      "",
      "app.listen(${2:3000}, () => console.log(\"http://localhost:${2:3000}\"));"
    ],
    "description": "Setup cơ bản cho file app.js với Express và EJS"
  },
  "AWS S3 & DynamoDB Config": {
    "prefix": "aws-config",
    "body": [
      "import aws from \"aws-sdk\"; ",
      "import dotenv from \"dotenv\";",
      "dotenv.config(); ",
      "",
      "aws.config.update({",
      "    region: process.env.REGION, ",
      "    accessKeyId: process.env.KEY, ",
      "    secretAccessKey: process.env.SEC,",
      "});",
      "",
      "export const dynamo = new aws.DynamoDB.DocumentClient();",
      "export const s3 = new aws.S3();"
    ],
    "description": "Cấu hình kết nối AWS SDK cho DynamoDB và S3"
  },
  "DynamoDB Model CRUD": {
    "prefix": "aws-model",
    "body": [
      "import { dynamo } from \"../config/aws.js\";",
      "",
      "const T = process.env.${1:DB};",
      "",
      "export const getAll = () => dynamo.scan({ TableName: T }).promise().then(d => d.Items);",
      "export const getById = (${2:id}) => dynamo.get({ TableName: T, Key: { ${2:id} } }).promise().then(d => d.Item);",
      "export const create = (Item) => dynamo.put({ TableName: T, Item }).promise();",
      "export const update = create;",
      "export const deleteItem = (${2:id}) => dynamo.delete({ TableName: T, Key: { ${2:id} } }).promise();",
      "export const deleteAll = async () => {",
      "  const items = await getAll();",
      "  await Promise.all(items.map((item) => deleteItem(item.${2:id})));",
      "};"
    ],
    "description": "Tạo nhanh các hàm CRUD cho DynamoDB model"
  },
  "Express Router with Multer": {
    "prefix": "ex-router",
    "body": [
      "import express from \"express\"; ",
      "import multer from \"multer\";",
      "import * as ctrl from \"../controllers/${1:soft}.controller.js\";",
      "",
      "const router = express.Router();",
      "const upload = multer({ dest: process.env.PR });",
      "",
      "router.get(\"/\", ctrl.index);",
      "router.get(\"/add\", ctrl.showAdd);",
      "router.post(\"/add\", upload.single(\"image\"), ctrl.add);",
      "router.get(\"/edit/:id\", ctrl.showEdit);",
      "router.post(\"/edit/:id\", upload.single(\"image\"), ctrl.edit);",
      "router.get(\"/delete/:id\", ctrl.deteleSoft);",
      "router.get(\"/detail/:id\", ctrl.detail);",
      "router.post(\"/delete-all\", ctrl.deleteAll);",
      "",
      "export default router;"
    ],
    "description": "Khởi tạo Express router tích hợp Multer upload file"
  },
  "Express Controller with S3 & CRUD": {
    "prefix": "ex-ctrl",
    "body": [
      "import fs from \"fs\";",
      "import * as ${1:Soft} from \"../models/${2:soft}.model.js\";",
      "import { s3 } from \"../config/aws.js\";",
      "import { v4 as uuid } from \"uuid\";",
      "",
      "export const uploadFile = async (file) => {",
      "  const fileContent = fs.readFileSync(file.path);",
      "",
      "  const params = {",
      "    Bucket: process.env.BK,",
      "    Key: process.env.PR + file.filename,",
      "    Body: fileContent,",
      "  };",
      "",
      "  await s3.upload(params).promise();",
      "  fs.unlinkSync(file.path);",
      "  return \\`https://\\${process.env.CDN}/\\${params.Key}\\`;",
      "};",
      "",
      "export const deleteFile = async (fileUrl) => {",
      "  if (!fileUrl) return;",
      "  const key = fileUrl.split(\"/\").pop();",
      "  await s3",
      "    .deleteObject({",
      "      Bucket: process.env.BK,",
      "      Key: process.env.PR + key,",
      "    })",
      "    .promise();",
      "};",
      "",
      "export const index = async (req, res) => {",
      "  const items = await ${1:Soft}.getAll();",
      "  const q = req.query.q;",
      "",
      "  if (q) items = items.filter((s) => s.toLowerCase().includes(q.toLowerCase()));",
      "",
      "  res.render(\"index\", {",
      "    softs: items,",
      "    keyword: q,",
      "  });",
      "};",
      "",
      "export const detail = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "  res.render(\"detail\", {",
      "    s,",
      "  });",
      "};",
      "",
      "export const deteleSoft = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "  ",
      "  if (s) {",
      "    await deleteFile(s.imageUrl);",
      "    await ${1:Soft}.deleteItem(req.params.id);",
      "  }",
      "  res.redirect(\"/\");",
      "};",
      "",
      "export const showAdd = async (req, res) => {",
      "  res.render(\"form\", {",
      "    title: \"Add\",",
      "    action: \"/add\",",
      "    data: {},",
      "    errors: [],",
      "  });",
      "};",
      "",
      "function validate(data) {",
      "  const errors = [];",
      "  if(!data.unitPrice || Number(data.unitPrice) <= 0) { ",
      "      errors.push(\"price phair > 0\");",
      "  }",
      "  if(!data.seats || Number(data.seats) <= 0) { ",
      "      errors.push(\"seats phair > 0\");",
      "  }",
      "  if(new Date(data.expiryDate) < new Date()){",
      "        errors.push(\"Ngay khon hop le\");",
      "  }",
      "  if(![\"Standard\", \"Professional\", \"Enterprise\"].includes(data.licenseTier)){",
      "      errors.push(\"Cac gia tri phai la Standard / Professional / Enterprise\");",
      "  }",
      "  return errors;",
      "}",
      "",
      "const calculator = (unitPrice, seats , licenseTier) => {",
      "    const total = unitPrice * seats ; ",
      "    let finalAmount = total; ",
      "    if(licenseTier === \"Professional\" && seats > 15 ) { ",
      "        finalAmount = total * 0.8;",
      "    } else if(licenseTier === \"Enterprise\" && seats > 30 ) { ",
      "        finalAmount = total * 0.12;",
      "    }",
      "    return { ",
      "        total , ",
      "        finalAmount, ",
      "        discount : finalAmount < total ? \"Được ưu đãi\" : \"Không ưu đãi\"",
      "    }",
      "}",
      "",
      "export const add = async (req, res) => {",
      "  const errors = validate(req.body);",
      "  if (errors.length > 0) {",
      "    return res.render(\"form\", {",
      "      title: \"Add\",",
      "      action: \"/add\",",
      "      data: req.body,",
      "      errors,",
      "    });",
      "  }",
      "",
      "  const imageUrl = await uploadFile(req.file);",
      "  const seats = Number(req.body.seats);",
      "  const unitPrice = Number(req.body.unitPrice);",
      "  const licenseTier = req.body.licenseTier;",
      "  const pricing = calculator(unitPrice, seats, licenseTier);",
      "",
      "  const item = {",
      "    softwareId: uuid(),",
      "    softwareName: req.body.softwareName,",
      "    ownerDepartment: req.body.ownerDepartment,",
      "    licenseTier: licenseTier,",
      "    seats: seats,",
      "    unitPrice: unitPrice,",
      "    expiryDate: req.body.expiryDate,",
      "    status: req.body.status,",
      "    imageUrl: imageUrl,",
      "    createdAt: new Date().toISOString(),",
      "    total : pricing.total, ",
      "    finalAmount : pricing.finalAmount, ",
      "    discount : pricing.discount",
      "  };",
      "",
      "  await ${1:Soft}.create(item);",
      "  res.redirect(\"/\");",
      "};",
      "",
      "export const showEdit = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "  res.render(\"form\", {",
      "    title: \"Edit\",",
      "    action: \"/edit/\" + s.softwareId,",
      "    data: s,",
      "    errors: [],",
      "  });",
      "};",
      "",
      "export const edit = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "",
      "  if (req.file) {",
      "    if (s.imageUrl) {",
      "      await deleteFile(s.imageUrl);",
      "    }",
      "    await uploadFile(req.file);",
      "  }",
      "",
      "  s.softwareName = req.body.softwareName;",
      "  s.ownerDepartment = req.body.ownerDepartment;",
      "  s.licenseTier = req.body.licenseTier;",
      "  s.seats = Number(req.body.seats);",
      "  s.unitPrice = Number(req.body.unitPrice);",
      "  s.expiryDate = req.body.expiryDate;",
      "  s.status = req.body.status;",
      "  s.createdAt = new Date().toISOString();",
      "",
      "  const pricing = calculator(s.unitPrice, s.seats, s.licenseTier);",
      "  s.total = pricing.total;",
      "  s.finalAmount = pricing.finalAmount;",
      "  s.discount = pricing.discount;",
      "     ",
      "  await ${1:Soft}.update(s);",
      "  res.redirect(\"/\");",
      "};",
      "",
      "export const deleteAll = async (req, res) => {",
      "  const items = await ${1:Soft}.getAll();",
      "  await Promise.all(items.map((s) => deleteFile(s.imageUrl)));",
      "  await ${1:Soft}.deleteAll();",
      "  res.redirect(\"/\");",
      "};"
    ],
    "description": "Controller mẫu xử lý upload S3, validation, tính toán giá và CRUD đầy đủ"
  }
}
