{
  "AWS Environment Variables": {
    "prefix": "aws-env",
    "body": [
      "REGION=",
      "KEY=",
      "SEC=",
      "",
      "DB=",
      "BK=",
      "PR=",
      "CDN="
    ],
    "description": "Các biến môi trường cho AWS S3 và DynamoDB"
  },
  "Express App Boilerplate": {
    "prefix": "ex-app",
    "body": [
      "import express from \"express\";",
      "import dotenv from \"dotenv\";",
      "import router from \"./routes/${1:soft}.route.js\";",
      "",
      "const app = express(); ",
      "dotenv.config(); ",
      "app.set(\"view engine\", \"ejs\"); ",
      "app.use(express.urlencoded({ extended: true })); ",
      "app.use(\"/\", router);",
      "",
      "app.listen(${2:3000}, () => console.log(\"http://localhost:${2:3000}\"));"
    ],
    "description": "Setup cơ bản cho file app.js với Express và EJS"
  },
  "AWS S3 & DynamoDB Config": {
    "prefix": "aws-config",
    "body": [
      "import aws from \"aws-sdk\"; ",
      "import dotenv from \"dotenv\";",
      "dotenv.config(); ",
      "",
      "aws.config.update({",
      "    region: process.env.REGION, ",
      "    accessKeyId: process.env.KEY, ",
      "    secretAccessKey: process.env.SEC,",
      "});",
      "",
      "export const dynamo = new aws.DynamoDB.DocumentClient();",
      "export const s3 = new aws.S3();"
    ],
    "description": "Cấu hình kết nối AWS SDK cho DynamoDB và S3"
  },
  "Express Router with Multer": {
    "prefix": "ex-router",
    "body": [
      "import express from \"express\"; ",
      "import multer from \"multer\";",
      "import * as ctrl from \"../controllers/${1:soft}.controller.js\";",
      "",
      "const router = express.Router();",
      "const upload = multer({ dest: process.env.PR });",
      "",
      "router.get(\"/\", ctrl.index);",
      "router.get(\"/add\", ctrl.showAdd);",
      "router.post(\"/add\", upload.single(\"image\"), ctrl.add);",
      "router.get(\"/edit/:id\", ctrl.showEdit);",
      "router.post(\"/edit/:id\", upload.single(\"image\"), ctrl.edit);",
      "router.get(\"/delete/:id\", ctrl.deleteSoft);",
      "router.get(\"/detail/:id\", ctrl.detail);",
      "router.post(\"/delete-all\", ctrl.deleteAll);",
      "",
      "export default router;"
    ],
    "description": "Khởi tạo Express router tích hợp Multer upload file"
  },
  "DynamoDB Model Init": {
    "prefix": "aws-model-init",
    "body": [
      "import { dynamo } from \"../config/aws.js\";",
      "",
      "const T = process.env.${1:DB};"
    ],
    "description": "Khởi tạo T (TableName) cho DynamoDB Model"
  },
  "DynamoDB Model GetAll": {
    "prefix": "aws-model-getAll",
    "body": [
      "export const getAll = () => dynamo.scan({ TableName: T }).promise().then(d => d.Items);"
    ],
    "description": "Hàm lấy tất cả items từ DynamoDB"
  },
  "DynamoDB Model GetById": {
    "prefix": "aws-model-getById",
    "body": [
      "export const getById = (${1:id}) => dynamo.get({ TableName: T, Key: { ${1:id} } }).promise().then(d => d.Item);"
    ],
    "description": "Hàm lấy 1 item theo ID từ DynamoDB"
  },
  "DynamoDB Model Create": {
    "prefix": "aws-model-create",
    "body": [
      "export const create = (Item) => dynamo.put({ TableName: T, Item }).promise();"
    ],
    "description": "Hàm tạo mới 1 item trong DynamoDB"
  },
  "DynamoDB Model Update": {
    "prefix": "aws-model-update",
    "body": [
      "export const update = create;"
    ],
    "description": "Hàm cập nhật item trong DynamoDB (tương đương create)"
  },
  "DynamoDB Model DeleteItem": {
    "prefix": "aws-model-deleteItem",
    "body": [
      "export const deleteItem = (${1:id}) => dynamo.delete({ TableName: T, Key: { ${1:id} } }).promise();"
    ],
    "description": "Hàm xóa 1 item theo ID trong DynamoDB"
  },
  "DynamoDB Model DeleteAll": {
    "prefix": "aws-model-deleteAll",
    "body": [
      "export const deleteAll = async () => {",
      "  const items = await getAll();",
      "  await Promise.all(items.map((item) => deleteItem(item.${1:id})));",
      "};"
    ],
    "description": "Hàm xóa toàn bộ items trong bảng DynamoDB"
  },
  "Express Controller Init": {
    "prefix": "ex-ctrl-init",
    "body": [
      "import fs from \"fs\";",
      "import * as ${1:Soft} from \"../models/${2:soft}.model.js\";",
      "import { s3 } from \"../config/aws.js\";",
      "import { v4 as uuid } from \"uuid\";"
    ],
    "description": "Import các thư viện cơ bản cho Controller"
  },
  "Express Controller Upload File": {
    "prefix": "ex-ctrl-uploadfile",
    "body": [
      "export const uploadFile = async (file) => {",
      "  const fileContent = fs.readFileSync(file.path);",
      "",
      "  const params = {",
      "    Bucket: process.env.BK,",
      "    Key: process.env.PR + file.filename,",
      "    Body: fileContent,",
      "  };",
      "",
      "  await s3.upload(params).promise();",
      "  fs.unlinkSync(file.path);",
      "  return \\`https://\\${process.env.CDN}/\\${params.Key}\\`;",
      "};"
    ],
    "description": "Hàm upload file lên S3"
  },
  "Express Controller Delete File": {
    "prefix": "ex-ctrl-deletefile",
    "body": [
      "export const deleteFile = async (fileUrl) => {",
      "  if (!fileUrl) return;",
      "  const key = fileUrl.split(\"/\").pop();",
      "  await s3",
      "    .deleteObject({",
      "      Bucket: process.env.BK,",
      "      Key: process.env.PR + key,",
      "    })",
      "    .promise();",
      "};"
    ],
    "description": "Hàm xóa file trên S3"
  },
  "Express Controller Index": {
    "prefix": "ex-ctrl-index",
    "body": [
      "export const index = async (req, res) => {",
      "  let ${2:softs} = await ${1:Soft}.getAll();",
      "  const q = req.query.q;",
      "",
      "  if (q) ${2:softs} = ${2:softs}.filter((s) => s.softwareName?.toLowerCase().includes(q.toLowerCase()));",
      "",
      "  res.render(\"index\", {",
      "    ${2:softs},",
      "    keyword: q,",
      "  });",
      "};"
    ],
    "description": "Controller xử lý trang danh sách kèm tìm kiếm"
  },
  "Express Controller Detail": {
    "prefix": "ex-ctrl-detail",
    "body": [
      "export const detail = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "  res.render(\"detail\", {",
      "    s,",
      "  });",
      "};"
    ],
    "description": "Controller xử lý xem chi tiết"
  },
  "Express Controller Delete Soft": {
    "prefix": "ex-ctrl-deleteSoft",
    "body": [
      "export const deteleSoft = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "  ",
      "  if (s) {",
      "    await deleteFile(s.imageUrl);",
      "    await ${1:Soft}.deleteItem(req.params.id);",
      "  }",
      "  res.redirect(\"/\");",
      "};"
    ],
    "description": "Controller xử lý xóa 1 item và file trên S3"
  },
  "Express Controller Show Add": {
    "prefix": "ex-ctrl-showAdd",
    "body": [
      "export const showAdd = async (req, res) => {",
      "  res.render(\"form\", {",
      "    title: \"Add\",",
      "    action: \"/add\",",
      "    data: {},",
      "    errors: [],",
      "  });",
      "};"
    ],
    "description": "Controller hiển thị form thêm mới"
  },
  "Express Controller Validate": {
    "prefix": "ex-ctrl-validate",
    "body": [
      "function validate(data) {",
      "  const errors = [];",
      "  if(!data.unitPrice || Number(data.unitPrice) <= 0) { ",
      "      errors.push(\"price phải > 0\");",
      "  }",
      "  if(!data.seats || Number(data.seats) <= 0) { ",
      "      errors.push(\"seats phải > 0\");",
      "  }",
      "  if(new Date(data.expiryDate) < new Date()){",
      "        errors.push(\"Ngày không hợp lệ\");",
      "  }",
      "  if(![\"Standard\", \"Professional\", \"Enterprise\"].includes(data.licenseTier)){",
      "      errors.push(\"Các giá trị phải là Standard / Professional / Enterprise\");",
      "  }",
      "  return errors;",
      "}"
    ],
    "description": "Hàm validate dữ liệu form"
  },
  "Express Controller Calculator": {
    "prefix": "ex-ctrl-calculator",
    "body": [
      "const calculator = (unitPrice, seats, licenseTier) => {",
      "    const total = unitPrice * seats; ",
      "    let finalAmount = total; ",
      "    if(licenseTier === \"Professional\" && seats > 15 ) { ",
      "        finalAmount = total * 0.8;",
      "    } else if(licenseTier === \"Enterprise\" && seats > 30 ) { ",
      "        finalAmount = total * 0.12;",
      "    }",
      "    return { ",
      "        total, ",
      "        finalAmount, ",
      "        discount : finalAmount < total ? \"Được ưu đãi\" : \"Không ưu đãi\"",
      "    }",
      "}"
    ],
    "description": "Hàm tính toán giá và ưu đãi"
  },
  "Express Controller Build Object": {
    "prefix": "ex-ctrl-buildObj",
    "body": [
      "const buildObject = (body, imageUrl, id = uuid()) => {",
      "  const { softwareName, ownerDepartment, licenseTier, status, expiryDate } = body;",
      "  const seats      = Number(body.seats);",
      "  const unitPrice  = Number(body.unitPrice);",
      "  const pricing    = calculator(unitPrice, seats, licenseTier);",
      "",
      "  return {",
      "    softwareId: id,",
      "    softwareName,",
      "    ownerDepartment,",
      "    licenseTier,",
      "    seats,",
      "    unitPrice,",
      "    expiryDate,",
      "    status,",
      "    imageUrl,",
      "    createdAt: new Date().toISOString(),",
      "    ...pricing,",
      "  };",
      "};"
    ],
    "description": "Hàm build object để map dữ liệu body trước khi đưa vào DB"
  },
  "Express Controller Add": {
    "prefix": "ex-ctrl-add",
    "body": [
      "export const add = async (req, res) => {",
      "  const errors = validate(req.body);",
      "  if (errors.length > 0) {",
      "    return res.render(\"form\", {",
      "      title: \"Add\",",
      "      action: \"/add\",",
      "      data: req.body,",
      "      errors,",
      "    });",
      "  }",
      "",
      "  const imageUrl = await uploadFile(req.file);",
      "",
      "  await ${1:Soft}.create(buildObject(req.body, imageUrl));",
      "  res.redirect(\"/\");",
      "};"
    ],
    "description": "Controller xử lý logic thêm mới dữ liệu"
  },
  "Express Controller Show Edit": {
    "prefix": "ex-ctrl-showEdit",
    "body": [
      "export const showEdit = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "  res.render(\"form\", {",
      "    title: \"Edit\",",
      "    action: \"/edit/\" + s.softwareId,",
      "    data: s,",
      "    errors: [],",
      "  });",
      "};"
    ],
    "description": "Controller hiển thị form chỉnh sửa"
  },
  "Express Controller Edit": {
    "prefix": "ex-ctrl-edit",
    "body": [
      "export const edit = async (req, res) => {",
      "  const s = await ${1:Soft}.getById(req.params.id);",
      "  let { imageUrl } = s; ",
      "  ",
      "  if (req.file) {",
      "    if (s.imageUrl) {",
      "      await deleteFile(s.imageUrl);",
      "    }",
      "    imageUrl = await uploadFile(req.file); ",
      "  }",
      "  ",
      "  await ${1:Soft}.update(buildObject(req.body, imageUrl, s.softwareId));",
      "  res.redirect(\"/\");",
      "};"
    ],
    "description": "Controller xử lý logic cập nhật dữ liệu"
  },
  "Express Controller Delete All": {
    "prefix": "ex-ctrl-deleteAll",
    "body": [
      "export const deleteAll = async (req, res) => {",
      "  const ${2:softs} = await ${1:Soft}.getAll();",
      "  await Promise.all(${2:softs}.map((s) => deleteFile(s.imageUrl)));",
      "  await ${1:Soft}.deleteAll();",
      "  res.redirect(\"/\");",
      "};"
    ],
    "description": "Controller xử lý xóa toàn bộ dữ liệu và file S3"
  }
}